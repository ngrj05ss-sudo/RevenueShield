<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RevenueShield | Fair Revenue Distribution</title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-surface-950 min-h-screen flex items-center justify-center p-4">
  <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 animate-fade-in">
    <!-- Creator Side -->
    <div class="glass-card p-10 flex flex-col items-center text-center group hover:border-primary-500/50 transition-all duration-500">
      <div class="w-16 h-16 bg-primary-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
        <svg class="w-8 h-8 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <h2 class="text-3xl font-bold text-white mb-4">Content Creator</h2>
      <p class="text-surface-400 mb-8 leading-relaxed">Access your personal dashboard to track engagement, transparency scores, and your monthly revenue share.</p>
      <a href="/auth/creator/login" class="btn-primary w-full py-4 text-lg">Creator Login</a>
      <a href="/auth/register" class="mt-4 text-sm text-surface-500 hover:text-primary-400 transition-colors">Don't have an account? Sign up</a>
    </div>

    <!-- Admin Side -->
    <div class="glass-card p-10 flex flex-col items-center text-center group hover:border-red-500/50 transition-all duration-500">
      <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
        <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <h2 class="text-3xl font-bold text-white mb-4">Administrator</h2>
      <p class="text-surface-400 mb-8 leading-relaxed">Manage the platform, monitor for manipulation, and execute the final revenue distribution cycles.</p>
      <a href="/auth/admin/login" class="btn-secondary w-full py-4 text-lg border-red-500/30 text-red-400 hover:bg-red-500/10">Admin Access</a>
      <p class="mt-4 text-xs text-surface-600 uppercase tracking-widest font-bold">Authorized Personnel Only</p>
    </div>
  </div>
</body>
</html>
