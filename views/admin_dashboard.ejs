<%- include('partials/header') %>

<!-- Admin Header -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8 animate-fade-in">
  <div>
    <h1 class="text-3xl font-bold bg-gradient-to-r from-white via-surface-200 to-surface-400 bg-clip-text text-transparent">
      Admin Command Center
    </h1>
    <p class="text-surface-400 mt-1 text-sm">Monitoring platform health and distribution integrity</p>
  </div>
  <div class="flex items-center gap-3">
    <button onclick="runDetection()" class="btn-secondary" id="btn-detect">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Audit Anomalies
      </span>
    </button>
    <button onclick="runDistribution()" class="btn-primary" id="btn-distribute">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Distribute Revenue
      </span>
    </button>
  </div>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-label">Pending Pool</div>
    <div class="stat-value">$<%= latestRevenue ? latestRevenue.totalPool.toLocaleString() : '0' %></div>
    <div class="text-xs text-primary-400 mt-1">Rules: V(<%= (latestRevenue.distributionRules.views * 100).toFixed(0) %>%) L(<%= (latestRevenue.distributionRules.likes * 100).toFixed(0) %>%)</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">System Flagged</div>
    <div class="stat-value text-red-400"><%= flaggedCount %></div>
    <div class="text-xs text-surface-500 mt-1">Requires admin review</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Avg. Trust Score</div>
    <% 
      let avgTrust = creators.reduce((acc, c) => acc + c.trustScore, 0) / creators.length;
    %>
    <div class="stat-value <%= avgTrust >= 80 ? 'text-emerald-400' : 'text-amber-400' %>"><%= avgTrust.toFixed(1) %></div>
    <div class="text-xs text-surface-500 mt-1">Global platform health</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Volume</div>
    <div class="stat-value text-blue-400">$<%= totalDistributed.toLocaleString() %></div>
    <div class="text-xs text-surface-500 mt-1">Lifetime distribution</div>
  </div>
</div>

<!-- Charts -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <div class="glass-card p-6">
    <h2 class="section-title mb-4">Platform Engagement Trends</h2>
    <div class="h-64"><canvas id="engagementChart"></canvas></div>
  </div>
  <div class="glass-card p-6">
    <h2 class="section-title mb-4">Distribution Weights</h2>
    <div class="h-64"><canvas id="weightsChart"></canvas></div>
  </div>
</div>

<!-- Anomaly Alert Banner (Admin Exclusive) -->
<% if (recentAnomalies.length > 0) { %>
<div class="glass-card border-red-500/30 p-6 mb-8 bg-red-500/5">
  <h2 class="section-title text-red-400 mb-4 flex items-center gap-2">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
    Critical Anomalies Detected
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
    <% recentAnomalies.forEach(function(a) { %>
    <div class="p-3 rounded-xl bg-surface-900/50 border border-red-500/20 hover:border-red-500/50 transition-all">
      <div class="flex items-center justify-between mb-2">
        <span class="font-bold text-white"><%= a.creatorId ? a.creatorId.name : 'Unknown' %></span>
        <span class="badge-danger">Score: <%= a.anomalyScore %></span>
      </div>
      <p class="text-[10px] text-surface-400 leading-tight mb-2"><%= a.reason %></p>
      <div class="flex items-center justify-between">
        <span class="text-[10px] text-surface-500"><%= new Date(a.createdAt).toLocaleTimeString() %></span>
        <a href="/dashboard/admin/creator/<%= a.creatorId._id %>?admin=true" class="text-[10px] text-primary-400 hover:underline">Investigate →</a>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>


<!-- Revenue Pool Configuration & Latest Distribution -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <!-- Configuration Panel -->
  <div class="glass-card p-6 border-primary-500/20">
    <h2 class="section-title mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Revenue Pool Configuration
    </h2>
    <form id="config-form" class="space-y-4">
      <input type="hidden" id="revenue-id" value="<%= latestRevenue ? latestRevenue._id : '' %>">
      <div>
        <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Total Pool Amount ($)</label>
        <input type="number" id="config-pool" value="<%= latestRevenue ? latestRevenue.totalPool : 0 %>" class="input-field py-2 text-sm font-mono">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Views Weight (0-1)</label>
          <input type="number" step="0.01" id="weight-views" value="<%= latestRevenue ? latestRevenue.distributionRules.views : 0.4 %>" class="input-field py-2 text-sm font-mono">
        </div>
        <div>
          <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Likes Weight (0-1)</label>
          <input type="number" step="0.01" id="weight-likes" value="<%= latestRevenue ? latestRevenue.distributionRules.likes : 0.2 %>" class="input-field py-2 text-sm font-mono">
        </div>
        <div>
          <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Shares Weight (0-1)</label>
          <input type="number" step="0.01" id="weight-shares" value="<%= latestRevenue ? latestRevenue.distributionRules.shares : 0.1 %>" class="input-field py-2 text-sm font-mono">
        </div>
        <div>
          <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Watch Time Weight (0-1)</label>
          <input type="number" step="0.01" id="weight-watchTime" value="<%= latestRevenue ? latestRevenue.distributionRules.watchTime : 0.3 %>" class="input-field py-2 text-sm font-mono">
        </div>
      </div>
      <div class="flex items-center justify-between pt-2">
        <span id="weight-total" class="text-[10px] font-bold text-surface-500">Total Weight: 1.00</span>
        <button type="button" onclick="updatePoolConfig()" class="btn-primary py-2 px-6 text-sm">Save Rules</button>
      </div>
    </form>
  </div>

  <!-- Latest Distribution Summary -->
  <div class="glass-card p-6 overflow-hidden">
    <h2 class="section-title mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      Latest Distribution Summary
    </h2>
    <div class="overflow-x-auto max-h-72">
      <% if (latestDistribution) { %>
      <table class="w-full text-left text-[11px]">
        <thead class="border-b border-surface-800 text-surface-500 uppercase">
          <tr><th class="py-2">Creator</th><th class="py-2">Penalty</th><th class="py-2">Payout</th><th class="py-2">Share</th></tr>
        </thead>
        <tbody class="divide-y divide-surface-800/50">
          <% latestDistribution.payouts.sort((a,b) => b.payout - a.payout).slice(0, 8).forEach(function(p) { %>
          <tr class="<%= p.penaltyApplied > 0 ? 'text-red-300' : 'text-surface-200' %>">
            <td class="py-2 font-medium"><%= p.creatorId ? p.creatorId.name : 'N/A' %></td>
            <td class="py-2">
              <% if (p.penaltyApplied > 0) { %>
                <span class="text-red-400 font-bold">-<%= p.penaltyApplied %>%</span>
              <% } else { %>
                <span class="text-emerald-500">None</span>
              <% } %>
            </td>
            <td class="py-2 font-mono font-bold text-emerald-400">$<%= p.payout.toLocaleString() %></td>
            <td class="py-2 font-mono"><%= p.percentage %>%</td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (latestDistribution.payouts.length > 8) { %>
        <p class="text-[10px] text-center text-surface-500 mt-2">Showing top 8 of <%= latestDistribution.payouts.length %> creators</p>
      <% } %>
      <% } else { %>
        <div class="h-full flex items-center justify-center py-12 text-surface-600">
          <p>No distributions recorded yet</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Creator Monitoring List -->

<div class="glass-card mb-8">
  <div class="p-6 pb-0 flex items-center justify-between">
    <h2 class="section-title">Global Creator Monitoring</h2>
    <input type="text" id="creator-search" placeholder="Search..." class="input-field w-48 py-1.5" onkeyup="filterCreators(this.value)">
  </div>
  <div class="p-6">
    <table class="data-table" id="creator-table">
      <thead>
        <tr><th>Creator</th><th>Status</th><th>Risk</th><th>Trust</th><th>Total Earnings</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% creators.forEach(function(c) { %>
        <tr class="creator-row" data-name="<%= c.name.toLowerCase() %>">
          <td>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-surface-700 flex items-center justify-center text-xs font-bold text-white"><%= c.name.charAt(0) %></div>
              <div>
                <div class="font-medium text-sm text-white"><%= c.name %></div>
                <div class="text-[10px] text-surface-500"><%= c.email %></div>
              </div>
            </div>
          </td>
          <td><span class="badge-<%= c.isFrozen ? 'danger' : (c.status === 'active' ? 'success' : 'danger') %> text-[10px]"><%= c.isFrozen ? 'Frozen' : c.status %></span></td>
          <td>
            <div class="flex items-center gap-2">
              <span class="text-xs font-mono font-bold <%= c.maliciousScore > 50 ? 'text-red-400' : 'text-surface-500' %>"><%= c.maliciousScore %>%</span>
            </div>
          </td>
          <td>
            <div class="flex items-center gap-2">
              <div class="w-12 h-1 bg-surface-800 rounded-full overflow-hidden">
                <div class="h-full bg-primary-500" style="width: <%= c.trustScore %>%"></div>
              </div>
              <span class="text-xs font-mono"><%= c.trustScore %></span>
            </div>
          </td>
          <td class="font-mono text-emerald-400 text-sm">$<%= c.totalEarnings.toLocaleString() %></td>
          <td><a href="/dashboard/admin/creator/<%= c._id %>?admin=true" class="text-xs text-primary-400 hover:text-white transition-colors">Drill-Down →</a></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<!-- Admin Management (Admin Only Section) -->
<div class="glass-card mb-8 border-primary-500/20">
  <div class="p-6">
    <h2 class="section-title mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      Admin Management
    </h2>
    <div class="flex flex-col md:flex-row items-end gap-4">
      <div class="flex-1">
        <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">New Admin Email</label>
        <input type="email" id="new-admin-email" placeholder="admin@example.com" class="input-field py-2 text-sm">
      </div>
      <div class="flex-1">
        <label class="block text-[10px] text-surface-500 uppercase font-bold mb-1 ml-1">Temporary Password</label>
        <input type="password" id="new-admin-password" placeholder="••••••••" class="input-field py-2 text-sm">
      </div>
      <button onclick="createAdmin()" class="btn-secondary whitespace-nowrap h-10">Create Admin</button>
    </div>
    <p class="text-[10px] text-surface-600 mt-3 italic">* Admins have full access to platform metrics and distribution controls.</p>
  </div>
</div>

<script>
async function createAdmin() {
  const email = document.getElementById('new-admin-email').value;
  const password = document.getElementById('new-admin-password').value;
  if (!email || !password) return alert('Please fill all fields');
  
  try {
    const res = await fetch('/auth/admin/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password })
    });
    const data = await res.json();
    if (data.success) {
      alert('Admin created successfully!');
      location.reload();
    } else {
      alert(data.message || 'Error creating admin');
    }
  } catch (err) {
    alert('Network error');
  }
}

async function updatePoolConfig() {
  const id = document.getElementById('revenue-id').value;
  const totalPool = parseFloat(document.getElementById('config-pool').value);
  const distributionRules = {
    views: parseFloat(document.getElementById('weight-views').value),
    likes: parseFloat(document.getElementById('weight-likes').value),
    shares: parseFloat(document.getElementById('weight-shares').value),
    watchTime: parseFloat(document.getElementById('weight-watchTime').value)
  };

  const totalWeight = Object.values(distributionRules).reduce((a, b) => a + b, 0);
  if (Math.abs(totalWeight - 1.0) > 0.001) {
    if (!confirm(`Warning: Total weights sum to ${totalWeight.toFixed(2)}, not 1.00. Continue?`)) return;
  }

  try {
    const method = id ? 'PUT' : 'POST';
    const url = id ? `/api/revenue/${id}` : '/api/revenue';
    
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ totalPool, distributionRules })
    });
    const data = await res.json();
    if (data.success) {
      alert('Configuration updated successfully!');
      location.reload();
    } else {
      alert(data.message || 'Error updating configuration');
    }
  } catch (err) {
    alert('Network error');
  }
}

// Live weight total tracking
document.querySelectorAll('#config-form input[type="number"]').forEach(input => {
  input.addEventListener('input', () => {
    const views = parseFloat(document.getElementById('weight-views').value) || 0;
    const likes = parseFloat(document.getElementById('weight-likes').value) || 0;
    const shares = parseFloat(document.getElementById('weight-shares').value) || 0;
    const watchTime = parseFloat(document.getElementById('weight-watchTime').value) || 0;
    const total = views + likes + shares + watchTime;
    const el = document.getElementById('weight-total');
    el.textContent = `Total Weight: ${total.toFixed(2)}`;
    el.className = `text-[10px] font-bold ${Math.abs(total - 1.0) < 0.001 ? 'text-emerald-400' : 'text-red-400'}`;
  });
});
</script>

<script id="timeline-data" type="application/json"><%- JSON.stringify(engagementTimeline) %></script>
<script id="weights-data" type="application/json"><%- JSON.stringify(latestRevenue ? latestRevenue.distributionRules : {views:0.3,likes:0.25,shares:0.2,watchTime:0.25}) %></script>

<%- include('partials/footer') %>
