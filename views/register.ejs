<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Creator Signup | RevenueShield</title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-surface-950 min-h-screen flex items-center justify-center p-4">
  <!-- Ambient Background -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary-600/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl"></div>
  </div>

  <div class="w-full max-w-md animate-fade-in">
    <div class="glass-card p-8 shadow-2xl border-surface-700/50">
      <div class="flex flex-col items-center mb-8">
        <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-primary-500 rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-emerald-500/25">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white">Join as Creator</h1>
        <p class="text-surface-400 text-sm mt-1">Start earning fairly for your content</p>
      </div>

      <% if (error) { %>
        <div class="mb-6 p-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm text-center">
          <%= error %>
        </div>
      <% } %>

      <form action="/auth/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-surface-400 uppercase tracking-wider mb-1.5 ml-1">Full Name</label>
          <input type="text" name="name" required placeholder="John Doe" class="input-field">
        </div>
        <div>
          <label class="block text-xs font-semibold text-surface-400 uppercase tracking-wider mb-1.5 ml-1">Email Address</label>
          <input type="email" name="email" required placeholder="john@example.com" class="input-field">
        </div>
        <div>
          <label class="block text-xs font-semibold text-surface-400 uppercase tracking-wider mb-1.5 ml-1">Password</label>
          <input type="password" name="password" required placeholder="Min. 6 characters" minlength="6" class="input-field">
        </div>
        
        <button type="submit" class="btn-primary w-full py-3 mt-4 bg-gradient-to-r from-emerald-600 to-primary-600 hover:from-emerald-500 hover:to-primary-500 shadow-emerald-500/20">
          Create Creator Account
        </button>
      </form>

      <div class="mt-8 pt-6 border-t border-surface-800 text-center">
        <p class="text-sm text-surface-500">
          Already a member? 
          <a href="/auth/login" class="text-primary-400 font-semibold hover:text-primary-300 transition-colors ml-1">Sign in here</a>
        </p>
      </div>
    </div>
  </div>
</body>
</html>
