<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Access | RevenueShield</title>
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="bg-surface-950 min-h-screen flex items-center justify-center p-4">
  <!-- Ambient Background (Admin Red Theme) -->
  <div class="fixed inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-red-600/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-surface-800/10 rounded-full blur-3xl"></div>
  </div>

  <div class="w-full max-w-md animate-fade-in">
    <div class="glass-card p-8 shadow-2xl border-red-500/20">
      <div class="flex flex-col items-center mb-8">
        <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-surface-700 rounded-2xl flex items-center justify-center mb-4 shadow-lg shadow-red-500/25">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-white">Admin Command Center</h1>
        <p class="text-surface-400 text-sm mt-1">Authorized Personnel Only</p>
      </div>

      <% if (error) { %>
        <div class="mb-6 p-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm text-center">
          <%= error %>
        </div>
      <% } %>

      <form action="/auth/admin/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-surface-400 uppercase tracking-wider mb-1.5 ml-1">Admin ID (Email)</label>
          <input type="email" name="email" required placeholder="admin@revenueshield.io" class="input-field border-surface-700 focus:border-red-500/50">
        </div>
        <div>
          <label class="block text-xs font-semibold text-surface-400 uppercase tracking-wider mb-1.5 ml-1">Security Key</label>
          <input type="password" name="password" required placeholder="••••••••" class="input-field border-surface-700 focus:border-red-500/50">
        </div>
        
        <button type="submit" class="btn-primary w-full py-3 mt-4 bg-gradient-to-r from-red-600 to-surface-800 hover:from-red-500 hover:to-surface-700 shadow-red-900/20">
          Enter Command Center
        </button>
      </form>

      <div class="mt-8 pt-6 border-t border-surface-800 text-center">
        <p class="text-xs text-surface-500">
          Not an admin? 
          <a href="/auth/creator/login" class="text-primary-400 font-semibold hover:text-primary-300 transition-colors ml-1">Creator Login</a>
        </p>
      </div>
    </div>
  </div>
</body>
</html>
