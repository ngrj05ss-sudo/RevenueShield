{
  "name": "creator-revenue-distribution-engine",
  "version": "1.0.0",
  "description": "Creator Revenue Distribution Engine with Manipulation Resistance",
  "main": "app.js",
  "scripts": {
    "prestart": "powershell -Command \"try { Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } } catch {} exit 0\"",
    "start": "node app.js",
    "dev": "nodemon app.js",
    "seed": "node seed.js",
    "css:build": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "css:watch": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-mongodb-session": "^5.0.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "express-validator": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "session-file-store": "^1.5.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.10"
  }
}
